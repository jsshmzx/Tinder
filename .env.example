# ================================================================
# Tinder 环境变量模板
# 复制此文件为 .env 并根据需要修改
# ================================================================

# === 运行环境 ===
APP_ENV=development

# === 服务器 ===
SERVER_HOST=0.0.0.0
SERVER_PORT=1912
SERVER_RELOAD=true
TZ=Asia/Shanghai

# === API ===
API_V1_PREFIX=/api/v1

# === CORS ===
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

# === 数据库（必填）===
DATABASE_URL=postgresql://postgres:password@localhost:5432/tinder

# === Redis（必填）===
REDIS_URL=redis://localhost:6379/0

# === Redis 连接管理 ===
REDIS_INITIAL_RETRY_INTERVAL=2
REDIS_MAX_RETRY_INTERVAL=60
REDIS_HEARTBEAT_INTERVAL=10

# === JWT（必填 — 生产环境务必使用随机长字符串）===
JWT_SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
TEMP_TOKEN_EXPIRE_MINUTES=15
JWT_ALGORITHM=HS256

# === 数据库连接池 ===
DB_POOL_PRE_PING=true

# === 用户认证缓存 ===
AUTH_USER_CACHE_TTL_SECONDS=60

# === 防火墙 ===
# FW_ENABLED: 防火墙总开关，设为 false 可完全关闭防火墙中间件
FW_ENABLED=true
FW_MAX_REQUESTS_PER_SECOND=20
FW_BAN_THRESHOLD=10
FW_BAN_DURATION=86400

# === 登录限流 ===
LOGIN_MAX_ATTEMPTS_PER_IP_PER_MINUTE=20
LOGIN_MAX_ATTEMPTS_PER_USERNAME_PER_MINUTE=5
LOGIN_RATE_WINDOW_SECONDS=60

# === 注册 ===
REG_MAX_IP_ATTEMPTS_PER_DAY=10
REG_MAX_NAME_ATTEMPTS_PER_DAY=3
REG_MAX_SHEET_ATTEMPTS=3
REG_MAX_SHEETS_PER_IP_PER_DAY=4
REG_CORRECT_THRESHOLD=3
REG_QUESTION_COUNT=5
REG_SHEET_TTL_SECONDS=86400
ACCOUNT_DELETION_GRACE_DAYS=30
MAX_PWD_CHG_ATTEMPTS_PER_DAY=10

# === 定时任务 ===
CRON_CLEANUP_INTERVAL_HOURS=1

# === 安全清理 ===
REFRESH_TOKEN_CLEANUP_DAYS=7

# === 超级密码（用于高危操作，如删除用户等） ===
SUPER_PASSWORD=your-super-secure-password
